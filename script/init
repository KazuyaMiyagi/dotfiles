#! /usr/bin/env bash

set -eu
set -o pipefail

cd "$(dirname "${0}")/.."

DOTFILE_ROOT_DIR="$(pwd)"
readonly DOTFILE_ROOT_DIR
BACKUP_DIR="${DOTFILE_ROOT_DIR}/backup"
readonly BACKUP_DIR

# shellcheck disable=SC1091
source "${DOTFILE_ROOT_DIR}/zsh/autoload/100-xdg.zsh"

function create_symlink() {
    local source_path="${1}"
    local target_path="${2}"
    local backup_name="${3}"

    echo "==> Creating symbolic link ${source_path} -> ${target_path}"

    if [ -L "${target_path}" ]; then
        echo "${target_path} symbolic link found. Unlinking ${target_path}."
        unlink "${target_path}"
    elif [ -e "${target_path}" ]; then
        echo "${target_path} found. Backing up to ${BACKUP_DIR}/${backup_name}"
        mv "${target_path}" "${BACKUP_DIR}/${backup_name}"
    fi

    ln -s "${source_path}" "${target_path}"

    echo -e "==> Symbolic link created successfully!\n"
}

function merge_managed_block() {
    local source_path="${1}"
    local target_path="${2}"
    local marker_label="${3}"
    local marker_begin="# >>> dotfiles managed (${marker_label}) >>>"
    local marker_end="# <<< dotfiles managed (${marker_label}) <<<"

    echo "==> Merging ${source_path} into ${target_path}"

    touch "${target_path}"

    awk -v begin="${marker_begin}" -v end="${marker_end}" '
        $0 == begin { skip = 1; next }
        $0 == end   { skip = 0; next }
        !skip       { print }
    ' "${target_path}" >"${target_path}.tmp"

    {
        printf "%s\n" "${marker_begin}"
        cat "${source_path}"
        printf "%s\n" "${marker_end}"
    } >>"${target_path}.tmp"

    mv "${target_path}.tmp" "${target_path}"

    echo -e "==> Managed block merged successfully!\n"
}

echo "Starting initialization..."

if [ ! -d "${BACKUP_DIR}" ]; then
    echo "Creating ${BACKUP_DIR}"
    mkdir "${BACKUP_DIR}"
fi

# Setup ~/.config symlink
create_symlink "${DOTFILE_ROOT_DIR}" "${XDG_CONFIG_HOME}" "config"

# Setup ~/tool-versions symlink
create_symlink "${DOTFILE_ROOT_DIR}/asdf/tool-versions" "${HOME}/tool-versions" "tool-versions"

# Setup ~/.tflint.hcl symlink
create_symlink "${DOTFILE_ROOT_DIR}/tflint/tflint.hcl" "${HOME}/.tflint.hcl" "tflint.hcl"

# Setup ~/.claude/settings.json
create_symlink "${DOTFILE_ROOT_DIR}/claude/settings.json" "${HOME}/.claude/settings.json" "claude_settings.json"

# Setup ~/.claude/CLAUDE.md
create_symlink "${DOTFILE_ROOT_DIR}/claude/CLAUDE.md" "${HOME}/.claude/CLAUDE.md" "claude_CLAUDE.md"

# Setup ~/.codex
if [ ! -d "${HOME}/.codex" ]; then
    echo "Creating ${HOME}/.codex"
    mkdir -p "${HOME}/.codex"
fi

# Setup ~/.codex/AGENTS.md
create_symlink "${DOTFILE_ROOT_DIR}/claude/CLAUDE.md" "${HOME}/.codex/AGENTS.md" "codex_AGENTS.md"

# Setup ~/.codex/config.toml
merge_managed_block "${DOTFILE_ROOT_DIR}/codex/config.toml" "${HOME}/.codex/config.toml" "codex"

# Setup ~/.zshenv
if [ -f "${HOME}/.zshenv" ]; then
    echo "${HOME}/.zshenv found. Backing up to ${BACKUP_DIR}/zshenv"
    mv "${HOME}/.zshenv" "${BACKUP_DIR}/zshenv"
fi
echo "Creating ${HOME}/.zshenv"
echo "export ZDOTDIR=${XDG_CONFIG_HOME}/zsh" >"${HOME}/.zshenv"

# Setup ~/.local/share/zsh
if [ ! -d "${XDG_DATA_HOME}/zsh" ]; then
    echo "Creating ${XDG_DATA_HOME}/zsh"
    mkdir -p "${XDG_DATA_HOME}/zsh"
fi

# Setup Touch ID for sudo
if [ ! -f /etc/pam.d/sudo_local ]; then
    echo "==> Enabling Touch ID for sudo..."
    sudo cp /etc/pam.d/sudo_local.template /etc/pam.d/sudo_local
    sudo sed -i '' 's/^#auth       sufficient     pam_tid.so/auth       sufficient     pam_tid.so/' /etc/pam.d/sudo_local
    echo "==> Touch ID for sudo enabled."
else
    echo "==> Touch ID for sudo was already configured."
fi

echo "Initialization finished!"
